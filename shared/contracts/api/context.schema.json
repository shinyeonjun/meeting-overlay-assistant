{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/contracts/api/context.schema.json",
  "title": "ContextContracts",
  "type": "object",
  "required": [
    "account_create_request",
    "account_response",
    "account_list_response",
    "contact_create_request",
    "contact_response",
    "contact_list_response",
    "context_thread_create_request",
    "context_thread_response",
    "context_thread_list_response"
  ],
  "properties": {
    "account_create_request": { "$ref": "#/$defs/accountCreateRequest" },
    "account_response": { "$ref": "#/$defs/accountResponse" },
    "account_list_response": { "$ref": "#/$defs/accountListResponse" },
    "contact_create_request": { "$ref": "#/$defs/contactCreateRequest" },
    "contact_response": { "$ref": "#/$defs/contactResponse" },
    "contact_list_response": { "$ref": "#/$defs/contactListResponse" },
    "context_thread_create_request": { "$ref": "#/$defs/contextThreadCreateRequest" },
    "context_thread_response": { "$ref": "#/$defs/contextThreadResponse" },
    "context_thread_list_response": { "$ref": "#/$defs/contextThreadListResponse" }
  },
  "$defs": {
    "accountCreateRequest": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "accountResponse": {
      "type": "object",
      "required": ["id", "workspace_id", "name", "status", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string" },
        "workspace_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "created_by_user_id": { "type": ["string", "null"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "accountListResponse": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/accountResponse" }
        }
      },
      "additionalProperties": false
    },
    "contactCreateRequest": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "account_id": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"] },
        "job_title": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "contactResponse": {
      "type": "object",
      "required": ["id", "workspace_id", "name", "status", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string" },
        "workspace_id": { "type": "string" },
        "account_id": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "email": { "type": ["string", "null"] },
        "job_title": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "created_by_user_id": { "type": ["string", "null"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "contactListResponse": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/contactResponse" }
        }
      },
      "additionalProperties": false
    },
    "contextThreadCreateRequest": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "account_id": { "type": ["string", "null"] },
        "contact_id": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "contextThreadResponse": {
      "type": "object",
      "required": ["id", "workspace_id", "title", "status", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string" },
        "workspace_id": { "type": "string" },
        "account_id": { "type": ["string", "null"] },
        "contact_id": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "summary": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "created_by_user_id": { "type": ["string", "null"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "contextThreadListResponse": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/contextThreadResponse" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
