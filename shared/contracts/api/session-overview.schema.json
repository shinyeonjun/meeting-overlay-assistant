{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/contracts/api/session-overview.schema.json",
  "title": "SessionOverviewResponse",
  "type": "object",
  "required": [
    "session",
    "current_topic",
    "questions",
    "decisions",
    "action_items",
    "risks",
    "workspace_summary",
    "workspace_summary_status",
    "metrics"
  ],
  "properties": {
    "session": {
      "type": "object",
      "required": [
        "id",
        "title",
        "mode",
        "status",
        "primary_input_source",
        "actual_active_sources"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": ["string", "null"] },
        "mode": { "type": "string" },
        "status": { "type": "string" },
        "started_at": { "type": ["string", "null"] },
        "ended_at": { "type": ["string", "null"] },
        "primary_input_source": { "type": "string" },
        "actual_active_sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "current_topic": { "type": ["string", "null"] },
    "questions": { "$ref": "#/$defs/eventList" },
    "decisions": { "$ref": "#/$defs/eventList" },
    "action_items": { "$ref": "#/$defs/eventList" },
    "risks": { "$ref": "#/$defs/eventList" },
    "workspace_summary": {
      "anyOf": [
        { "$ref": "#/$defs/workspaceSummary" },
        { "type": "null" }
      ]
    },
    "workspace_summary_status": {
      "anyOf": [
        { "$ref": "#/$defs/workspaceSummaryStatus" },
        { "type": "null" }
      ]
    },
    "metrics": {
      "type": "object",
      "required": [
        "recent_utterance_count_by_source"
      ],
      "properties": {
        "recent_average_latency_ms": { "type": ["number", "null"] },
        "recent_utterance_count_by_source": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "insight_metrics": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "integer" }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "eventItem": {
      "type": "object",
      "required": [
        "id",
        "title",
        "state"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "state": { "type": "string" },
        "speaker_label": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "eventList": {
      "type": "array",
      "items": { "$ref": "#/$defs/eventItem" }
    },
    "workspaceSummaryActionItem": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "owner": { "type": ["string", "null"] },
        "due_date": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "workspaceSummaryEvidence": {
      "type": "object",
      "required": ["label", "start_ms", "end_ms"],
      "properties": {
        "label": { "type": "string" },
        "start_ms": { "type": "integer" },
        "end_ms": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "workspaceSummaryTopic": {
      "type": "object",
      "required": ["title", "summary", "start_ms", "end_ms"],
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "start_ms": { "type": "integer" },
        "end_ms": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "workspaceSummary": {
      "type": "object",
      "required": [
        "headline",
        "summary",
        "topics",
        "decisions",
        "next_actions",
        "open_questions",
        "changed_since_last_meeting",
        "evidence",
        "model"
      ],
      "properties": {
        "headline": { "type": "string" },
        "summary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "topics": {
          "type": "array",
          "items": { "$ref": "#/$defs/workspaceSummaryTopic" }
        },
        "decisions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/workspaceSummaryActionItem" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "changed_since_last_meeting": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/workspaceSummaryEvidence" }
        },
        "model": { "type": "string" }
      },
      "additionalProperties": true
    },
    "workspaceSummaryStatus": {
      "type": "object",
      "required": ["status", "source_version", "model", "error_message", "updated_at"],
      "properties": {
        "status": { "type": "string" },
        "source_version": { "type": "integer" },
        "model": { "type": "string" },
        "error_message": { "type": ["string", "null"] },
        "updated_at": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
