{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/contracts/api/events.schema.json",
  "title": "EventContracts",
  "type": "object",
  "required": [
    "event_item",
    "event_list_response",
    "event_update_request",
    "event_transition_request",
    "bulk_event_transition_request",
    "bulk_event_transition_response"
  ],
  "properties": {
    "event_item": { "$ref": "#/$defs/eventItem" },
    "event_list_response": { "$ref": "#/$defs/eventListResponse" },
    "event_update_request": { "$ref": "#/$defs/eventUpdateRequest" },
    "event_transition_request": { "$ref": "#/$defs/eventTransitionRequest" },
    "bulk_event_transition_request": { "$ref": "#/$defs/bulkEventTransitionRequest" },
    "bulk_event_transition_response": { "$ref": "#/$defs/bulkEventTransitionResponse" }
  },
  "$defs": {
    "eventItem": {
      "type": "object",
      "required": [
        "id",
        "session_id",
        "event_type",
        "title",
        "state",
        "created_at_ms",
        "updated_at_ms"
      ],
      "properties": {
        "id": { "type": "string" },
        "session_id": { "type": "string" },
        "event_type": {
          "type": "string",
          "enum": ["topic", "question", "decision", "action_item", "risk"]
        },
        "title": { "type": "string" },
        "body": { "type": ["string", "null"] },
        "evidence_text": { "type": ["string", "null"] },
        "speaker_label": { "type": ["string", "null"] },
        "state": {
          "type": "string",
          "enum": ["active", "open", "answered", "confirmed", "updated", "resolved", "closed"]
        },
        "source_utterance_id": { "type": ["string", "null"] },
        "created_at_ms": { "type": "integer" },
        "updated_at_ms": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "eventListResponse": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/eventItem" }
        }
      },
      "additionalProperties": false
    },
    "eventUpdateRequest": {
      "type": "object",
      "properties": {
        "event_type": {
          "type": ["string", "null"],
          "enum": ["topic", "question", "decision", "action_item", "risk", null]
        },
        "title": { "type": ["string", "null"], "minLength": 1 },
        "body": { "type": ["string", "null"] },
        "state": {
          "type": ["string", "null"],
          "enum": ["active", "open", "answered", "confirmed", "updated", "resolved", "closed", null]
        },
        "evidence_text": { "type": ["string", "null"] },
        "speaker_label": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "eventTransitionRequest": {
      "type": "object",
      "required": ["target_state"],
      "properties": {
        "target_state": {
          "type": "string",
          "enum": ["active", "open", "answered", "confirmed", "updated", "resolved", "closed"]
        },
        "title": { "type": ["string", "null"], "minLength": 1 },
        "body": { "type": ["string", "null"] },
        "evidence_text": { "type": ["string", "null"] },
        "speaker_label": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "bulkEventTransitionRequest": {
      "type": "object",
      "required": ["event_ids", "target_state"],
      "properties": {
        "event_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "target_state": {
          "type": "string",
          "enum": ["active", "open", "answered", "confirmed", "updated", "resolved", "closed"]
        }
      },
      "additionalProperties": false
    },
    "bulkEventTransitionResponse": {
      "type": "object",
      "required": ["updated_count", "target_state", "items"],
      "properties": {
        "updated_count": { "type": "integer" },
        "target_state": {
          "type": "string",
          "enum": ["active", "open", "answered", "confirmed", "updated", "resolved", "closed"]
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/eventItem" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
