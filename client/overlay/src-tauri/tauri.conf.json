{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meeting Overlay HUD",
  "version": "0.1.0",
  "identifier": "com.caps.overlay",
  "build": {
    "beforeDevCommand": "npm run overlay:dev",
    "beforeBuildCommand": "npm run overlay:build",
    "frontendDist": "../dist/overlay",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "security": {
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "오버레이 창 기본 권한",
          "windows": [
            "overlay"
          ],
          "permissions": [
            "core:default",
            "core:event:default",
            "core:event:allow-listen",
            "core:event:allow-emit",
            "core:window:default",
            "core:window:allow-set-ignore-cursor-events",
            "core:window:allow-set-always-on-top",
            "core:window:allow-set-size",
            "core:window:allow-set-position",
            "core:window:allow-current-monitor",
            "core:window:allow-outer-position",
            "core:window:allow-scale-factor",
            "core:window:allow-hide",
            "core:window:allow-close"
          ]
        }
      ]
    },
    "windows": [
      {
        "label": "overlay",
        "title": "Meeting Overlay HUD",
        "width": 800,
        "height": 600,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
