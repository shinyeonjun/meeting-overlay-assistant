# 애플리케이션
APP_NAME=meeting-overlay-assistant
APP_ENV=development
DEBUG=true
SERVER_HOST=127.0.0.1
SERVER_PORT=8011
LIVE_SERVER_PORT=8012

# 데이터베이스 / 큐
POSTGRESQL_DSN=postgresql://caps:caps@127.0.0.1:55432/caps
TEST_POSTGRESQL_DSN=postgresql://caps:caps@127.0.0.1:55432/caps_test
REDIS_URL=redis://127.0.0.1:56379/0
ARTIFACTS_ROOT_PATH=server/data/artifacts
REPORT_JOB_QUEUE_KEY=caps:queue:report-generation
REPORT_JOB_QUEUE_BLOCK_SECONDS=15
NOTE_CORRECTION_JOB_QUEUE_KEY=caps:queue:note-correction
NOTE_CORRECTION_JOB_QUEUE_BLOCK_SECONDS=15
NOTE_CORRECTION_JOB_FALLBACK_POLL_SECONDS=30
PIPELINE_JOB_MAX_ATTEMPTS=3
PIPELINE_JOB_HEARTBEAT_INTERVAL_SECONDS=15
PIPELINE_RECOVERY_SESSION_LIMIT=500
REPORT_JOB_FALLBACK_POLL_SECONDS=30
LIVE_QUESTION_ANALYSIS_ENABLED=false
LIVE_QUESTION_REQUEST_STREAM_KEY=caps:live_question:requests
LIVE_QUESTION_RESULT_STREAM_KEY=caps:live_question:results
LIVE_QUESTION_STREAM_BLOCK_SECONDS=5
LIVE_QUESTION_DEBOUNCE_MS=600
LIVE_QUESTION_WINDOW_SIZE=4
AUTH_ENABLED=false
SERVER_SETTINGS_PROFILE=
AUTH_SESSION_TTL_HOURS=12
ANALYSIS_RULES_CONFIG_PATH=server/config/analysis_rules.json
TRANSCRIPTION_GUARD_CONFIG_PATH=server/config/transcription_guard.json

# 오디오 전처리 / 화자 분리
AUDIO_PREPROCESSOR_BACKEND=bypass
AUDIO_PREPROCESSOR_MODEL_PATH=
AUDIO_PREPROCESSOR_ATTEN_LIM_DB=18
SPEAKER_DIARIZER_BACKEND=unknown_speaker
SPEAKER_DIARIZER_MODEL_ID=pyannote/speaker-diarization-community-1
SPEAKER_DIARIZER_AUTH_TOKEN=
SPEAKER_DIARIZER_DEVICE=cpu
SPEAKER_DIARIZER_DEFAULT_LABEL=speaker-unknown
SPEAKER_DIARIZER_WORKER_PYTHON=
SPEAKER_DIARIZER_WORKER_SCRIPT_PATH=server/scripts/workers/pyannote_worker.py
SPEAKER_DIARIZER_WORKER_TIMEOUT_SECONDS=120

# STT
# 권장 기본값:
# - live: Sherpa + Faster-Whisper 하이브리드
# - 최종 기록: Faster-Whisper
STT_BACKEND=faster_whisper_streaming
STT_BACKEND_SYSTEM_AUDIO=hybrid_local_streaming_sherpa
STT_MODEL_ID=deepdml/faster-whisper-large-v3-turbo-ct2
STT_MODEL_PATH=server/models/stt/faster-whisper-large-v3-turbo-ct2
STT_PRELOAD_ON_STARTUP=true
STT_BASE_MODEL_ID=openai/whisper-small
STT_ENCODER_MODEL_PATH=D:\caps\server\models\stt\amd-whisper-small-onnx-npu\encoder_model.onnx
STT_DECODER_MODEL_PATH=D:\caps\server\models\stt\amd-whisper-small-onnx-npu\decoder_model.onnx
STT_ENCODER_RAI_PATH=D:\caps\server\models\stt\amd-whisper-small-onnx-npu\ggml-small-encoder-vitisai.rai
STT_BASE_URL=http://127.0.0.1:8001/v1/audio
STT_API_KEY=
STT_TIMEOUT_SECONDS=20
STT_LANGUAGE=ko
STT_INITIAL_PROMPT=
STT_DEVICE=auto
STT_COMPUTE_TYPE=default
LIVE_STREAM_WORKER_COUNT=1
LIVE_STREAM_PENDING_CHUNKS_PER_STREAM=3
LIVE_STREAM_MAX_RUNNING_SESSIONS=4
STT_CPU_THREADS=0
STT_BEAM_SIZE=1
STT_SAMPLE_RATE_HZ=16000
STT_SAMPLE_WIDTH_BYTES=2
STT_CHANNELS=1
STT_SILENCE_RMS_THRESHOLD=0.003
VAD_FRAME_DURATION_MS=30
VAD_PRE_ROLL_MS=300
VAD_POST_ROLL_MS=450
VAD_MIN_SPEECH_MS=240
VAD_MAX_SEGMENT_MS=5000
VAD_MIN_ACTIVATION_FRAMES=2
VAD_RMS_THRESHOLD=0.01
VAD_ADAPTIVE_NOISE_FLOOR_ALPHA=0.92
VAD_ADAPTIVE_THRESHOLD_MULTIPLIER=1.9
VAD_ACTIVE_THRESHOLD_RATIO=0.8
VAD_MIN_VOICED_RATIO=0.18
VAD_POST_ROLL_MS_SYSTEM_AUDIO=650
VAD_MIN_SPEECH_MS_SYSTEM_AUDIO=180
VAD_MIN_ACTIVATION_FRAMES_SYSTEM_AUDIO=2
VAD_RMS_THRESHOLD_SYSTEM_AUDIO=0.008
VAD_ADAPTIVE_THRESHOLD_MULTIPLIER_SYSTEM_AUDIO=1.55
VAD_ACTIVE_THRESHOLD_RATIO_SYSTEM_AUDIO=0.72
VAD_MIN_VOICED_RATIO_SYSTEM_AUDIO=0.12
STT_MIN_CONFIDENCE=0.35
STT_MIN_CONFIDENCE_SYSTEM_AUDIO=0.6
STT_SHORT_TEXT_MIN_CONFIDENCE=0.6
STT_SHORT_TEXT_MIN_CONFIDENCE_SYSTEM_AUDIO=0.8
STT_MIN_COMPACT_LENGTH=2
STT_MAX_REPEAT_RATIO=0.6
STT_MAX_REPEAT_RATIO_SYSTEM_AUDIO=0.5
STT_MAX_CONSECUTIVE_REPEAT=4
STT_MAX_CONSECUTIVE_REPEAT_SYSTEM_AUDIO=3
STT_MIN_REPETITION_TOKENS=6
STT_MIN_REPETITION_TOKENS_SYSTEM_AUDIO=4
STT_DUPLICATE_WINDOW_MS=2500
STT_DUPLICATE_WINDOW_MS_SYSTEM_AUDIO=8000
STT_DUPLICATE_SIMILARITY_THRESHOLD=0.98
STT_DUPLICATE_SIMILARITY_THRESHOLD_SYSTEM_AUDIO=0.9
STT_DUPLICATE_MAX_CONFIDENCE=0.0
STT_DUPLICATE_MAX_CONFIDENCE_SYSTEM_AUDIO=0.8
STT_MAX_NO_SPEECH_PROB=1.0
STT_MAX_NO_SPEECH_PROB_SYSTEM_AUDIO=0.8
SILERO_VAD_ENABLED=false
SILERO_VAD_ENABLED_SYSTEM_AUDIO=false
SILERO_VAD_THRESHOLD=0.5
SILERO_VAD_MIN_SPEECH_MS=120
RYZEN_AI_INSTALLATION_PATH=C:\Program Files\RyzenAI\1.6.1

# NPU STT 실험 예시
# STT_BACKEND=amd_whisper_npu
# STT_MODEL_ID=amd/whisper-small-onnx-npu

# 로깅
LOG_LEVEL=INFO
LOG_JSON=false
LOG_FILE_PATH=server/data/logs/caps-server.log

# 분석기 / 리포트 / 요약기
ANALYZER_BACKEND=insight_pipeline
LLM_PROVIDER_BACKEND=ollama
LLM_MODEL=qwen2.5:3b-instruct
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=20

LIVE_QUESTION_LLM_BACKEND=ollama
LIVE_QUESTION_LLM_MODEL=qwen2.5:3b-instruct
LIVE_QUESTION_LLM_BASE_URL=http://127.0.0.1:11434/v1
LIVE_QUESTION_LLM_API_KEY=
LIVE_QUESTION_LLM_TIMEOUT_SECONDS=20
LIVE_QUESTION_LLM_KEEP_ALIVE=30m
# JSON object example: {"캡스":"CAPS","큐웬":"Qwen"}
LIVE_QUESTION_TERM_ALIASES_JSON=

REPORT_REFINER_BACKEND=noop
REPORT_REFINER_MODEL=qwen2.5:3b-instruct
REPORT_REFINER_BASE_URL=http://127.0.0.1:11434/v1
REPORT_REFINER_API_KEY=
REPORT_REFINER_TIMEOUT_SECONDS=20

NOTE_TRANSCRIPT_CORRECTION_ENABLED=false
NOTE_TRANSCRIPT_CORRECTION_BACKEND=ollama
NOTE_TRANSCRIPT_CORRECTION_MODEL=gemma4:e4b
NOTE_TRANSCRIPT_CORRECTION_BASE_URL=http://127.0.0.1:11434/v1
NOTE_TRANSCRIPT_CORRECTION_API_KEY=
NOTE_TRANSCRIPT_CORRECTION_TIMEOUT_SECONDS=30
NOTE_TRANSCRIPT_CORRECTION_MAX_WINDOW=3
NOTE_TRANSCRIPT_CORRECTION_MAX_CANDIDATES=12
NOTE_TRANSCRIPT_CORRECTION_MAX_CONFIDENCE_FOR_CORRECTION=0.72
NOTE_TRANSCRIPT_CORRECTION_SHORT_UTTERANCE_MAX_CHARS=12
NOTE_TRANSCRIPT_STT_MODEL_ID=Systran/faster-whisper-large-v3
NOTE_TRANSCRIPT_STT_MODEL_PATH=server/models/stt/faster-whisper-large-v3
NOTE_TRANSCRIPT_STT_BEAM_SIZE=5

TOPIC_SUMMARIZER_BACKEND=noop
TOPIC_SUMMARIZER_MODEL=qwen2.5:3b-instruct
TOPIC_SUMMARIZER_BASE_URL=http://127.0.0.1:11434/v1
TOPIC_SUMMARIZER_API_KEY=
TOPIC_SUMMARIZER_TIMEOUT_SECONDS=10
TOPIC_SUMMARY_RECENT_UTTERANCE_COUNT=5
TOPIC_SUMMARY_MIN_UTTERANCE_LENGTH=10
TOPIC_SUMMARY_MIN_UTTERANCE_CONFIDENCE=0.58
